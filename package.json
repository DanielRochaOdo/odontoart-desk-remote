{
  "name": "remote-support-suite",
  "private": true,
  "workspaces": [
    "server",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:server dev:agent dev:controller",
    "dev:server": "npm --workspace server run dev",
    "dev:agent": "npm --workspace @rss/agent run dev",
    "dev:controller": "npm --workspace @rss/controller run dev",
    "build": "npm-run-all build:server build:agent build:controller",
    "build:server": "npm --workspace server run build",
    "build:agent": "npm --workspace @rss/agent run build",
    "build:controller": "npm --workspace @rss/controller run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
